{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:legacy": "NODE_OPTIONS=--openssl-legacy-provider tsx server.ts",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=dist/server.js",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server.js",
    "pm2:start": "pm2 start dist/server.js --name pizza-city-backend --env NODE_ENV=production",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "expo": "^57.0.6",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.0.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "mongodb": "^7.5.0",
    "mongoose": "^9.6.3",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^4.0.0",
    "pm2": "^5.4.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^6.22.3",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
